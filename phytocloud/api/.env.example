# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Platform Domains ────────────────────────────────────
# Landing page domain
PLATFORM_DOMAIN=phytolabs.in

# Subdomain base for Rs 349 plan
SUBDOMAIN_BASE=carnivorousplants.in

# ── PayU Payment Gateway ─────────────────────────────────
# Test keys (swap for production keys when going live)
PAYU_KEY=REDACTED_PAYU_TEST_KEY
PAYU_SALT=REDACTED_PAYU_TEST_SALT
PAYU_ENV=test
# PAYU_ENV=prod

# Optional webhook secret for additional signature layer
PAYU_WEBHOOK_SECRET=

# ── Docker ───────────────────────────────────────────────
# Absolute path where per-tenant compose files are stored
TENANT_COMPOSE_DIR=/opt/phyto-tenants
# Absolute path to the compose template
COMPOSE_TEMPLATE_PATH=/opt/phyto-ecommerce-api/templates/docker-compose.tpl.yml
# Docker socket
DOCKER_SOCKET=/var/run/docker.sock

# ── SQLite Database ──────────────────────────────────────
DB_PATH=/opt/phyto-ecommerce-api/data/tenants.db

# ── Email — Mailgun (for subdomain plan tenants) ─────────
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=mg.carnivorousplants.in
FROM_EMAIL=noreply@carnivorousplants.in
FROM_NAME=Phyto E-Commerce

# ── Let's Encrypt ────────────────────────────────────────
ACME_EMAIL=admin@phytolabs.in

# ── Backups ──────────────────────────────────────────────
BACKUP_DIR=/opt/phyto-backups
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET_NAME=phyto-ecommerce-backups

# ── Security ─────────────────────────────────────────────
# Secret for internal API calls (provision/deprovision endpoints)
API_SECRET=change-me-to-a-long-random-string
