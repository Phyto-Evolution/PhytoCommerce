# Listmonk environment variables
# Copy this file to .env and fill in all values before running docker compose

# Database
DB_USER=listmonk
DB_PASSWORD=change_me_strong_password_here
DB_NAME=listmonk

# Listmonk admin credentials (set before first run)
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASS=change_me_strong_admin_password

# Platform domain (used for Traefik label: mail.PLATFORM_DOMAIN)
PLATFORM_DOMAIN=phytolabs.in
