{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Per-tenant resource usage overview for Phyto E-Commerce",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1100 },
              { "color": "red",    "value": 1400 }
            ]
          },
          "unit": "mbytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "title": "Tenant RAM Usage (MB)",
      "type": "gauge",
      "targets": [
        {
          "expr": "sum by (name) (container_memory_usage_bytes{name=~\"ps_.*\"}) / 1024 / 1024",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1.5 },
              { "color": "red",    "value": 1.9 }
            ]
          },
          "unit": "short",
          "max": 2.0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto" },
      "title": "Tenant CPU Usage (cores)",
      "type": "gauge",
      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"ps_.*\"}[5m]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "id": 3,
      "title": "Container Status — All Tenants",
      "type": "table",
      "targets": [
        {
          "expr": "container_last_seen{name=~\"ps_.*\"}",
          "legendFormat": "{{name}}",
          "refId": "A",
          "instant": true
        }
      ]
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["phyto", "tenants"],
  "title": "Phyto E-Commerce — Tenant Overview",
  "uid": "phyto-tenant-overview",
  "version": 1
}
