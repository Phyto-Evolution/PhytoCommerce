# ── Sidecar Config ────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── SQLite (same file as Spin's runtime-config.toml [sqlite_database.default]) ──
DB_PATH=/opt/phyto-ecommerce/data/tenants.db

# ── Docker ────────────────────────────────────────────────────────────────────
TENANT_COMPOSE_DIR=/opt/phyto-tenants
COMPOSE_TEMPLATE_PATH=/opt/phyto-ecommerce/spin/api/templates/docker-compose.tpl.yml
DOCKER_SOCKET=/var/run/docker.sock

# ── Domains ───────────────────────────────────────────────────────────────────
SUBDOMAIN_BASE=carnivorousplants.in

# ── Email — Mailgun (subdomain plan tenants only) ─────────────────────────────
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=mg.carnivorousplants.in
FROM_EMAIL=noreply@carnivorousplants.in
FROM_NAME=Phyto E-Commerce

# ── Backblaze B2 (optional offsite backup) ────────────────────────────────────
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET_NAME=phyto-ecommerce-backups
