{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-phyto-grex" class="btn btn-primary">
          <i class="fa fa-floppy-o"></i> {{ button_save }}
        </button>
        <a href="{{ cancel }}" class="btn btn-default">
          <i class="fa fa-reply"></i> {{ button_cancel }}
        </a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="container-fluid">

    {% if success %}
      <div class="alert alert-success alert-dismissible">
        <i class="fa fa-check-circle"></i> {{ success }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}

    {% if error_warning %}
      <div class="alert alert-danger alert-dismissible">
        <i class="fa fa-exclamation-circle"></i> {{ error_warning }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}

    {# ── Add / Edit form ── #}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title">
          <i class="fa fa-pencil"></i>
          {% if edit_record %}
            Edit Grex Record #{{ edit_record.grex_registry_id }}
          {% else %}
            {{ text_add_record }}
          {% endif %}
        </h3>
      </div>
      <div class="panel-body">
        <form id="form-phyto-grex" action="{{ action }}" method="post" enctype="multipart/form-data">

          {% if edit_record %}
            <input type="hidden" name="grex_registry_id" value="{{ edit_record.grex_registry_id }}" />
          {% endif %}

          <div class="form-group required">
            <label class="col-sm-2 control-label">{{ entry_product_id }}</label>
            <div class="col-sm-10">
              <input type="number" name="product_id" class="form-control"
                     value="{{ edit_record ? edit_record.product_id : '' }}"
                     min="1" placeholder="OpenCart product_id" />
              {% if error_product_id %}
                <div class="text-danger">{{ error_product_id }}</div>
              {% endif %}
            </div>
          </div>

          <div class="form-group required">
            <label class="col-sm-2 control-label">{{ entry_grex_id }}</label>
            <div class="col-sm-10">
              <input type="text" name="grex_id" class="form-control"
                     value="{{ edit_record ? edit_record.grex_id : '' }}" />
              {% if error_grex_id %}
                <div class="text-danger">{{ error_grex_id }}</div>
              {% endif %}
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_parent_a }}</label>
            <div class="col-sm-10">
              <input type="text" name="parent_a" class="form-control"
                     value="{{ edit_record ? edit_record.parent_a : '' }}" />
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_parent_b }}</label>
            <div class="col-sm-10">
              <input type="text" name="parent_b" class="form-control"
                     value="{{ edit_record ? edit_record.parent_b : '' }}" />
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_grex_year }}</label>
            <div class="col-sm-10">
              <input type="number" name="grex_year" class="form-control"
                     value="{{ edit_record ? edit_record.grex_year : '' }}"
                     min="1800" max="2100" placeholder="e.g. 2024" />
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_registrant }}</label>
            <div class="col-sm-10">
              <input type="text" name="registrant" class="form-control"
                     value="{{ edit_record ? edit_record.registrant : '' }}" />
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_species_status }}</label>
            <div class="col-sm-10">
              <select name="species_status" class="form-control">
                {% for status in valid_statuses %}
                  <option value="{{ status }}"
                    {% if edit_record and edit_record.species_status == status %}selected="selected"{% endif %}>
                    {{ status|capitalize }}
                  </option>
                {% endfor %}
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_taxonomy_pack }}</label>
            <div class="col-sm-10">
              <input type="text" name="taxonomy_pack" class="form-control"
                     value="{{ edit_record ? edit_record.taxonomy_pack : '' }}" />
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_notes }}</label>
            <div class="col-sm-10">
              <textarea name="notes" class="form-control" rows="4">{{ edit_record ? edit_record.notes : '' }}</textarea>
            </div>
          </div>

        </form>
      </div>
    </div>

    {# ── Records table ── #}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title">
          <i class="fa fa-list"></i> {{ text_all_records }}
        </h3>
      </div>
      <div class="panel-body">
        <div class="table-responsive">
          <table class="table table-bordered table-hover">
            <thead>
              <tr>
                <th>{{ column_grex_registry_id }}</th>
                <th>{{ column_product_id }}</th>
                <th>{{ column_grex_id }}</th>
                <th>{{ column_parent_a }}</th>
                <th>{{ column_parent_b }}</th>
                <th>{{ column_grex_year }}</th>
                <th>{{ column_registrant }}</th>
                <th>{{ column_species_status }}</th>
                <th>{{ column_taxonomy_pack }}</th>
                <th>{{ column_date_modified }}</th>
                <th>{{ column_action }}</th>
              </tr>
            </thead>
            <tbody>
              {% if records %}
                {% for record in records %}
                  <tr>
                    <td>{{ record.grex_registry_id }}</td>
                    <td>{{ record.product_id }}</td>
                    <td>{{ record.grex_id }}</td>
                    <td>{{ record.parent_a ? record.parent_a : '—' }}</td>
                    <td>{{ record.parent_b ? record.parent_b : '—' }}</td>
                    <td>{{ record.grex_year ? record.grex_year : '—' }}</td>
                    <td>{{ record.registrant ? record.registrant : '—' }}</td>
                    <td>{{ record.species_status }}</td>
                    <td>{{ record.taxonomy_pack ? record.taxonomy_pack : '—' }}</td>
                    <td>{{ record.date_modified }}</td>
                    <td>
                      <a href="{{ 'extension/module/phyto_grex_registry&user_token=' ~ user_token ~ '&edit_id=' ~ record.grex_registry_id }}"
                         class="btn btn-primary btn-xs">
                        <i class="fa fa-pencil"></i> Edit
                      </a>
                      <a href="{{ delete_url ~ '&delete_id=' ~ record.grex_registry_id }}"
                         class="btn btn-danger btn-xs"
                         onclick="return confirm('{{ text_confirm_delete }}');">
                        <i class="fa fa-trash-o"></i> {{ button_delete }}
                      </a>
                    </td>
                  </tr>
                {% endfor %}
              {% else %}
                <tr>
                  <td colspan="11" class="text-center">{{ text_none }}</td>
                </tr>
              {% endif %}
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </div>{# /container-fluid #}
</div>{# /content #}
{{ footer }}
