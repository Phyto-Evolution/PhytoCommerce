<div class="phyto-grex-registry">
  <h2 class="phyto-grex-registry__heading">{{ heading_grex_registry }}</h2>
  <dl class="phyto-grex-registry__dl">
    {% for field in fields %}
      <div class="phyto-grex-registry__row">
        <dt class="phyto-grex-registry__term">{{ field.label }}</dt>
        <dd class="phyto-grex-registry__desc">
          {% if field.is_notes is defined and field.is_notes %}
            <span class="phyto-grex-registry__notes">{{ field.value|nl2br }}</span>
          {% else %}
            {{ field.value }}
          {% endif %}
        </dd>
      </div>
    {% endfor %}
  </dl>
</div>

<style>
.phyto-grex-registry {
  padding: 20px 0;
}
.phyto-grex-registry__heading {
  font-size: 1.2em;
  margin-bottom: 16px;
  color: #333;
  border-bottom: 1px solid #e0e0e0;
  padding-bottom: 8px;
}
.phyto-grex-registry__dl {
  margin: 0;
}
.phyto-grex-registry__row {
  display: flex;
  padding: 6px 0;
  border-bottom: 1px solid #f5f5f5;
}
.phyto-grex-registry__row:last-child {
  border-bottom: none;
}
.phyto-grex-registry__term {
  flex: 0 0 200px;
  font-weight: 600;
  color: #555;
  margin: 0;
}
.phyto-grex-registry__desc {
  flex: 1;
  margin: 0;
  color: #333;
}
.phyto-grex-registry__notes {
  white-space: pre-line;
}
</style>
